{% extends 'base.html.twig' %}

{% block title %}Liste de tâches !{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>


    <h1>Toutes les tâches</h1>          
    {{form(form)}}
    

    {% for task in tasks %}

    <div class= "container">
    <h2> Tâche : {{task.title}}</h2>

    <form action="">
    <label for=""> Fait
    <input type="checkbox" name = "isDone" onChange = "submit()">
    </label>
    
    </form>
    
    {# <p> Fait : {{task.isDone ? 'Tâche faite : <input type ="checkbox" checked >': 'Tâche à faire :<input type ="checkbox" value = "!isDone">'}}</p> #}
   
    <small>Crée le : {{task.createdAt | date('d/m/Y H:i:s')}}</small>
    <hr>
    </div>
    {% endfor %}
    

{% endblock %}
